    "client:list": "tsx scripts/client-manager.ts list",
    "client:export": "tsx scripts/client-manager.ts export",
    "client:import": "tsx scripts/client-manager.ts import",
    "client:validate": "tsx scripts/client-manager.ts validate",
    "client:backup": "tsx scripts/client-manager.ts backup"
