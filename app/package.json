    "visual:report": "playwright show-report tests/visual-reports",
    "visual:update": "playwright test --update-snapshots",
    "perf:benchmark": "tsx scripts/performance/benchmark-components.ts",
    "perf:web-vitals": "tsx scripts/performance/core-web-vitals.ts",
    "perf:bundle": "tsx scripts/performance/bundle-analysis.ts",
    "perf:memory": "tsx scripts/performance/memory-profiling.ts",
    "perf:validate": "tsx scripts/performance/validate-performance.ts",
    "perf:all": "npm run perf:benchmark && npm run perf:bundle && npm run perf:web-vitals && npm run perf:memory",
    "coverage:gates": "tsx scripts/coverage-gates.ts",
    "coverage:report": "npm run test:coverage && npm run coverage:gates",
    "test:unit": "vitest run --config ./vite.config.test.ts",
    "test:watch": "vitest --config ./vite.config.test.ts",
    "test:ci": "npm run test:coverage && npm run coverage:gates",
