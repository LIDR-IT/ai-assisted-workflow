{
  "metadata": {
    "version": "1.0.0",
    "lastUpdated": "2026-04-02",
    "description": "Global default configuration for all clients and projects"
  },
  "theme": {
    "name": "default",
    "mode": "light"
  },
  "colors": {
    "primary": "bg-blue-500",
    "secondary": "bg-gray-100",
    "success": "bg-green-500",
    "warning": "bg-yellow-500",
    "error": "bg-red-500",
    "info": "bg-cyan-500",
    "neutral": "bg-gray-500",
    "background": "bg-white",
    "surface": "bg-gray-50",
    "border": "border-gray-200",
    "text": "text-gray-900",
    "textMuted": "text-gray-600",
    "accent": "text-blue-600"
  },
  "typography": {
    "fontFamily": "font-sans",
    "headings": {
      "h1": "text-3xl font-bold",
      "h2": "text-2xl font-semibold",
      "h3": "text-xl font-medium",
      "h4": "text-lg font-medium"
    },
    "body": {
      "base": "text-base",
      "small": "text-sm",
      "large": "text-lg"
    }
  },
  "layout": {
    "containerMaxWidth": "max-w-7xl",
    "spacing": {
      "xs": "gap-1",
      "sm": "gap-2",
      "md": "gap-4",
      "lg": "gap-6",
      "xl": "gap-8"
    },
    "borderRadius": {
      "sm": "rounded",
      "md": "rounded-md",
      "lg": "rounded-lg",
      "xl": "rounded-xl"
    }
  },
  "components": {
    "blocks": {
      "defaultSpacing": "space-y-6",
      "defaultPadding": "p-6",
      "showIcons": true,
      "showBorders": true,
      "collapsible": false
    },
    "diagrams": {
      "defaultHeight": 400,
      "showLegend": true,
      "exportFormat": "png",
      "interactivity": true
    },
    "navigation": {
      "showSidebar": true,
      "collapsibleSidebar": true,
      "breadcrumbs": true
    }
  },
  "features": {
    "customBlocks": true,
    "colorCustomization": true,
    "templateVariables": true,
    "export": {
      "pdf": true,
      "images": true,
      "json": true
    },
    "collaboration": {
      "comments": false,
      "realTimeEditing": false
    }
  },
  "performance": {
    "lazyLoading": true,
    "caching": {
      "enabled": true,
      "ttl": 300000
    },
    "bundleOptimization": true
  },
  "validation": {
    "strictMode": true,
    "showWarnings": true,
    "autoFix": false
  }
}
