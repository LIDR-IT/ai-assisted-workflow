  "tables": [
    {
      "label": "Siglas",
      "value": "PR = Pull Request · CI = Continuous Integration · DoD = Definition of Done · SAST = Static Application Security Testing · SCA = Software Composition Analysis · CR = Change Request · P1 = Prioridad 1"
    },
    {
      "label": "Por feature",
      "value": "/lidr-create-branch (desde develop) → /lidr-commit (conventional) → /lidr-create-pr → review + CI (Gate 4 DoD) → squash merge a develop"
    },
    {
      "label": "Por release",
      "value": "release/x.y.z desde develop → /lidr-create-release-notes (changelog desde PRs mergeados) → /lidr-update-changelog vX.Y.Z → merge a main + tag → deploy PROD (Gate 7)"
    },
    {
      "label": "Hotfix (P1)",
      "value": "hotfix/* desde main → fix → merge a main + develop (fast-track, CR retroactivo)"
    },
    {
      "label": "Atadura con PRDs",
      "value": "1 feature/story de un PRD = 1 rama + 1 PR; el PR referencia ticket + change; el release agrupa los PRs mergeados y de ahí sale el CHANGELOG"
    }
  ]
