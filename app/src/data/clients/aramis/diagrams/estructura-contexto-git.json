      "aramis"
    ],
    "implementation_status": {
      "level": "absent",
      "description": "Flujo propuesto (gitflow + comandos LIDR). 1 feature/story = 1 rama + 1 PR; el release agrupa los PRs mergeados y genera el changelog.",
      "evidence": "Branch strategy en .agents/rules/process/git-workflow.md (main/develop/feature/release/hotfix, squash a develop, merge commit a main) y comandos en .agents/rules/lidr-sdlc/workflows.md (/lidr-create-branch, /lidr-create-pr, /lidr-create-release-notes, /lidr-update-changelog)."
    }
  },
