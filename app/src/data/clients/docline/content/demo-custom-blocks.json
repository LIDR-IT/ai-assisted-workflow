      "content": {
        "problem": {
          "title": "¿Necesitas un nuevo tipo de componente?",
          "description": "Antes tenías que modificar el código base, actualizar schemas, y hacer deploy para agregar nuevos tipos de bloques."
        },
        "solution": {
          "title": "Ahora es súper simple",
          "items": [
            "Crear archivo TypeScript en src/app/components/content/blocks/custom/",
            "Seguir la convención: MiBlockPersonalizadoBlock.tsx → 'miblocpersonalizado'",
            "Exportar component como default export",
            "¡Automáticamente disponible en JSON content!"
          ]
        }
      }
    },
    {
