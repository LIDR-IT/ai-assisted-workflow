            "label": "1. Archivo: CustomTableBlock.tsx",
            "level": 0,
            "description": "Archivo en directorio custom/"
          },
          {
            "label": "export default function CustomTableBlock({ block })",
            "level": 1,
            "description": "Component principal con export default"
          },
          {
            "label": "const { colors } = useColorConfig(block.config?.colors)",
            "level": 2,
            "description": "Integración con sistema de colores"
          },
          {
            "label": "return <SectionBox>...</SectionBox>",
            "level": 2,
            "description": "Usar componentes compartidos"
          },
          {
            "label": "2. Uso en JSON:",
            "level": 0,
            "description": "Inmediatamente disponible"
          },
          {
            "label": "{ \"type\": \"customtable\", \"content\": {...} }",
            "level": 1,
            "description": "Auto-detectado como 'customtable'"
          }
        ]
