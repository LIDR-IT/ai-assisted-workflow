#!/bin/sh
# =============================================================================
# pre-push Hook (root)
# =============================================================================
# Validate branch naming convention before pushing.
# Pattern follows LIDR Guidelines.md §2.4 Naming.
# =============================================================================

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
VALID_PATTERN="^(main|develop|feature\/[A-Z]+-[0-9]+-[a-z0-9-]+|release\/v[0-9]+\.[0-9]+\.[0-9]+|hotfix\/[A-Z]+-[0-9]+-[a-z0-9-]+|chore\/[a-z0-9-]+|docs\/[a-z0-9-]+|fix\/[a-z0-9-]+|refactor\/[a-z0-9-]+)$"

if ! echo "$BRANCH" | grep -qE "$VALID_PATTERN"; then
  echo "❌ Branch name '$BRANCH' does not follow convention."
  echo "   Expected one of:"
  echo "     - main, develop"
  echo "     - feature/PROJ-123-description"
  echo "     - release/vX.Y.Z"
  echo "     - hotfix/PROJ-123-description"
  echo "     - chore|docs|fix|refactor/short-description"
  exit 1
fi

echo "✅ Pre-push checks passed (branch: $BRANCH)"
