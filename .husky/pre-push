#!/bin/sh
# =============================================================================
# pre-push Hook (root)
# =============================================================================
# 1. Validate branch naming convention (LIDR Guidelines §2.4).
# 2. Fast ecosystem-counts guard: catches the most common drift (adding an
#    artifact without updating CLAUDE.md). The deep coherence checks run in CI
#    via `app: npm run test:ecosystem` (test-coverage.yml). Keep this fast.
# =============================================================================

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
VALID_PATTERN="^(main|develop|feature\/[A-Z]+-[0-9]+-[a-z0-9-]+|release\/v[0-9]+\.[0-9]+\.[0-9]+|hotfix\/[A-Z]+-[0-9]+-[a-z0-9-]+|chore\/[a-z0-9-]+|docs\/[a-z0-9-]+|fix\/[a-z0-9-]+|refactor\/[a-z0-9-]+)$"

if ! echo "$BRANCH" | grep -qE "$VALID_PATTERN"; then
  echo "❌ Branch name '$BRANCH' does not follow convention."
  echo "   Expected one of:"
  echo "     - main, develop"
  echo "     - feature/PROJ-123-description"
  echo "     - release/vX.Y.Z"
  echo "     - hotfix/PROJ-123-description"
  echo "     - chore|docs|fix|refactor/short-description"
  exit 1
fi

COUNTS_HOOK=".agents/hooks/scripts/validate-ecosystem-counts.sh"
if [ -f "$COUNTS_HOOK" ]; then
  if ! sh "$COUNTS_HOOK" >/dev/null 2>&1; then
    echo "❌ Ecosystem counts drifted (skills/commands/rules/agents/hooks vs CLAUDE.md)."
    echo "   Run: bash $COUNTS_HOOK   to see the mismatch, then update CLAUDE.md."
    exit 1
  fi
fi

echo "✅ Pre-push checks passed (branch: $BRANCH, ecosystem counts OK)"
